# ==============================================
# Claude Creatives - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ---- Image Generation API (kie.ai) ----
# Get your API key at: https://kie.ai/api-key
# Sign up, add credits, and copy your API key
KIE_API_KEY=your_kie_api_key_here

# ---- Image Generation API (fal.ai) - Alternative ----
# Get your API key at: https://fal.ai/dashboard/keys
# Uncomment if you prefer to use fal.ai instead of kie.ai
# FAL_KEY=your_fal_api_key_here

# ---- Image Generation Provider ----
# Options: "kie" or "fal" (default: kie)
IMAGE_PROVIDER=kie

# ---- Image Generation Model ----
# Options: "nano-banana-pro" (recommended) or "nano-banana"
IMAGE_MODEL=nano-banana-pro

# ---- Late API Key (for Social Media Manager integration) ----
# Only needed for Phase 3 - connecting to EX Social Media Manager
# LATE_API_KEY=your_late_api_key_here

# ---- Image Upload (for image-to-image references) ----
# Used for uploading face/reference images for thumbnail generation
# Get your key at: https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_api_key_here
